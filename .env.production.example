# Database — use Railway's MySQL plugin URL
DATABASE_URL=mysql://user:password@host:port/dbname

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-long-random-secret-here

# Admin — email of the first admin user
ADMIN_EMAIL=leah@africacreativeagency.com

# Anthropic API key
OPENAI_API_KEY=sk-ant-...

# Google OAuth — update redirect URI to your production domain
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# CORS — your production frontend domain
CORS_ORIGIN=https://yourdomain.com

# AWS S3 — for file uploads
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket

# Server
PORT=3000
NODE_ENV=production
